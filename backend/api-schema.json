            "data": {
              "liked": "boolean"
            }
          }
        }
      },
      "POST /api/posts/:id/save": {
        "description": "Toggle save/bookmark on a post",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Post saved | Post unsaved",
            "data": {
              "saved": "boolean"
            }
          }
        }
      },
      "POST /api/posts/:id/report": {
        "description": "Report a post (one report per user per post)",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>",
          "Content-Type": "application/json"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": {
          "reason": { "type": "string", "required": false, "description": "Optional reason for reporting" }
        },
        "successResponse": {
          "status": 201,
          "body": {
            "success": true,
            "message": "Post reported successfully",
            "data": {
              "id": "string (uuid)",
              "reason": "string | null",
              "userId": "string (uuid)",
              "postId": "string (uuid)",
              "createdAt": "string (ISO)"
            }
          }
        }
      }
    },
