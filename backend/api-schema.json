    "upload": {
      "POST /api/upload": {
        "description": "Upload one or more images to S3. Returns S3 URLs to use in create post images array.",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>",
          "Content-Type": "multipart/form-data"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "images": { "type": "File[]", "required": true, "description": "Image files (JPEG, PNG, GIF, WebP). Max 4 files, 5MB each." },
          "fileType": { "type": "string", "required": false, "default": "post_image", "description": "e.g. post_image or avatar. Determines S3 folder." }
        },
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Images uploaded successfully",
            "data": [
              {
                "url": "string (S3 public URL)",
                "fileType": "string",
                "originalName": "string",
                "size": "number (bytes)",
                "mimeType": "string"
              }
            ]
          }
        }
      },
      "POST /api/upload/avatar": {
        "description": "Upload a single avatar image to S3",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>",
          "Content-Type": "multipart/form-data"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "avatar": { "type": "File", "required": true, "description": "Single image file (JPEG, PNG, GIF, WebP). Max 5MB." }
        },
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Avatar uploaded successfully",
            "data": {
              "url": "string (S3 public URL)",
              "fileType": "avatar",
              "originalName": "string",
              "size": "number (bytes)",
              "mimeType": "string"
            }
          }
        }
      }
    },
    "posts": {
      "GET /api/posts": {
        "description": "Get all active posts with optional filters (public, optional auth)",
        "auth": "optional",
        "headers": {
          "Authorization": "Bearer <accessToken> (optional)"
        },
        "pathParams": {},
        "queryParams": {
          "category": { "type": "string", "required": false, "enum": ["EVENT", "FOOD", "SPORTS", "DAYRO", "OTHER"] },
          "subcategory": { "type": "string", "required": false },
          "search": { "type": "string", "required": false, "description": "Search in title, content, tags" },
          "sort": { "type": "string", "required": false, "enum": ["latest", "popular", "upcoming"], "default": "latest" },
          "page": { "type": "string (number)", "required": false, "default": "1" },
          "limit": { "type": "string (number)", "required": false, "default": "10" }
        },
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Posts fetched successfully",
            "data": ["PostSummary[]"],
            "meta": "PaginationMeta"
          }
        }
      },
      "GET /api/posts/:id": {
        "description": "Get single post by ID with comments (increments view count)",
        "auth": "optional",
        "headers": {
          "Authorization": "Bearer <accessToken> (optional)"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Success",
            "data": {
              "_extends": "PostSummary",
              "comments": [
                {
                  "id": "string (uuid)",
                  "content": "string",
                  "authorId": "string",
                  "author": "AuthorSummary",
                  "postId": "string",
                  "parentId": "null",
                  "createdAt": "string (ISO)",
                  "replies": [
                    {
                      "id": "string (uuid)",
                      "content": "string",
                      "author": "AuthorSummary",
                      "parentId": "string",
                      "createdAt": "string (ISO)",
                      "replies": ["CommentItem[] (max 2 levels deep)"]
                    }
                  ]
                }
              ]
            }
          }
        }
      },
      "POST /api/posts": {
        "description": "Create a new post. Upload images first via /api/upload, then pass URLs here.",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>",
          "Content-Type": "application/json"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "title": { "type": "string", "required": true, "min": 3, "max": 200 },
          "content": { "type": "string", "required": true, "min": 10 },
          "category": { "type": "string", "required": true, "enum": ["EVENT", "FOOD", "SPORTS", "DAYRO", "OTHER"] },
          "subcategory": { "type": "string", "required": false, "max": 100 },
          "tags": { "type": "string | string[]", "required": false, "description": "Comma-separated string or array of strings" },
          "eventDate": { "type": "string", "required": false, "format": "ISO 8601 datetime with offset" },
          "eventVenue": { "type": "string", "required": false, "max": 200 },
          "isOngoing": { "type": "boolean | string", "required": false, "default": false },
          "address": { "type": "string", "required": false, "max": 300 },
          "locationCoordinate": { "type": "string", "required": false, "max": 100 },
          "images": { "type": "string[]", "required": false, "description": "Array of S3 image URLs from /api/upload" }
        },
        "successResponse": {
          "status": 201,
          "body": {
            "success": true,
            "message": "Post created successfully",
            "data": "PostSummary"
          }
        }
      },
      "PUT /api/posts/:id": {
        "description": "Update own post (partial update)",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>",
          "Content-Type": "application/json"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": {
          "_note": "All fields are optional (partial update)",
          "title": { "type": "string", "required": false, "min": 3, "max": 200 },
          "content": { "type": "string", "required": false, "min": 10 },
          "category": { "type": "string", "required": false, "enum": ["EVENT", "FOOD", "SPORTS", "DAYRO", "OTHER"] },
          "subcategory": { "type": "string", "required": false, "max": 100 },
          "tags": { "type": "string | string[]", "required": false },
          "eventDate": { "type": "string", "required": false, "format": "ISO 8601" },
          "eventVenue": { "type": "string", "required": false, "max": 200 },
          "isOngoing": { "type": "boolean | string", "required": false },
          "address": { "type": "string", "required": false, "max": 300 },
          "locationCoordinate": { "type": "string", "required": false, "max": 100 },
          "images": { "type": "string[]", "required": false, "description": "Array of S3 image URLs" }
        },
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Post updated successfully",
            "data": "PostSummary"
          }
        }
      },
      "DELETE /api/posts/:id": {
        "description": "Delete own post (admin can delete any)",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Post deleted successfully",
            "data": null
          }
        }
      },
      "POST /api/posts/:id/like": {
        "description": "Toggle like on a post",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>"
        },
        "pathParams": {
          "id": { "type": "string (uuid)", "required": true }
        },
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
