        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Success",
            "data": {
              "id": "string (uuid)",
              "username": "string",
              "email": "string",
              "displayName": "string",
              "avatar": "string | null",
              "bio": "string | null",
              "gender": "string | null",
              "role": "string",
              "createdAt": "string (ISO)",
              "updatedAt": "string (ISO)",
