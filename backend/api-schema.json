{
  "apiBaseUrl": "http://localhost:8080/api",
  "globalResponseWrapper": {
    "success": "boolean",
    "message": "string",
    "data": "T | undefined",
    "meta": "{ total: number, page: number, limit: number, totalPages: number } | undefined"
  },
  "enums": {
    "Role": ["USER", "ADMIN"],
    "Gender": ["MALE", "FEMALE", "OTHER"],
    "UserStatus": ["ACTIVE", "INACTIVE"],
    "PostCategory": ["EVENT", "FOOD", "SPORTS", "DAYRO", "OTHER"],
    "PostStatus": ["ACTIVE", "REMOVED"]
  },
  "sharedSchemas": {
    "AuthorSummary": {
      "id": "string (uuid)",
      "username": "string",
      "displayName": "string",
      "avatar": "string | null"
    },
    "PostSummary": {
      "id": "string (uuid)",
      "title": "string",
      "content": "string",
      "images": "string[]",
      "category": "PostCategory",
      "subcategory": "string | null",
      "tags": "string[]",
      "status": "PostStatus",
      "eventDate": "string (ISO) | null",
      "eventVenue": "string | null",
      "isOngoing": "boolean",
      "viewCount": "number",
      "address": "string | null",
      "locationCoordinate": "string | null",
      "authorId": "string",
      "author": "AuthorSummary",
      "createdAt": "string (ISO)",
      "updatedAt": "string (ISO)",
      "_count": {
        "likes": "number",
        "comments": "number"
      }
    },
    "PostSummaryAdmin": {
      "_extends": "PostSummary",
      "_count": {
        "likes": "number",
        "comments": "number",
        "reports": "number"
      }
    },
    "CommentItem": {
      "id": "string (uuid)",
      "content": "string",
      "authorId": "string",
      "author": "AuthorSummary",
      "postId": "string",
      "parentId": "string | null",
      "createdAt": "string (ISO)",
      "replies": "CommentItem[]"
    },
    "PaginationMeta": {
      "total": "number",
      "page": "number",
      "limit": "number",
      "totalPages": "number"
    }
  },
  "endpoints": {
