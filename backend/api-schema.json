      "GET /api/health": {
        "description": "Health check",
        "auth": false,
        "headers": {},
        "pathParams": {},
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "RajkotLive API is running",
            "timestamp": "string (ISO)"
          }
        }
      }
    },
    "genders": {
      "GET /api/genders": {
        "description": "Get list of gender options",
        "auth": false,
        "headers": {},
        "pathParams": {},
        "queryParams": {},
