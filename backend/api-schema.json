              { "value": "OTHER", "label": "Other" }
            ]
          }
        }
      }
    },
    "auth": {
      "POST /api/auth/register": {
        "description": "Register a new user",
        "auth": false,
        "headers": {
          "Content-Type": "application/json"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "username": { "type": "string", "required": true, "min": 3, "max": 30, "pattern": "^[a-zA-Z0-9_]+$" },
          "email": { "type": "string", "required": true, "format": "email" },
          "password": { "type": "string", "required": true, "min": 6, "max": 100 },
          "displayName": { "type": "string", "required": true, "min": 2, "max": 50 },
          "gender": { "type": "string", "required": false, "enum": ["MALE", "FEMALE", "OTHER"] }
        },
        "successResponse": {
          "status": 201,
          "body": {
            "success": true,
            "message": "Registration successful",
            "data": {
              "user": {
                "id": "string (uuid)",
                "username": "string",
                "email": "string",
                "displayName": "string",
                "gender": "string | null",
                "role": "string",
                "createdAt": "string (ISO)"
              },
              "accessToken": "string (JWT)",
              "refreshToken": "string (JWT)"
            }
          }
        }
      },
      "POST /api/auth/login": {
        "description": "Login with email and password",
        "auth": false,
        "headers": {
          "Content-Type": "application/json"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "email": { "type": "string", "required": true, "format": "email" },
          "password": { "type": "string", "required": true, "min": 1 }
        },
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Login successful",
            "data": {
              "user": {
                "id": "string (uuid)",
                "username": "string",
                "email": "string",
                "displayName": "string",
                "avatar": "string | null",
                "bio": "string | null",
                "role": "string",
                "gender": "string | null",
                "status": "string",
                "createdAt": "string (ISO)",
                "updatedAt": "string (ISO)"
              },
              "accessToken": "string (JWT)",
              "refreshToken": "string (JWT)"
            }
          }
        }
      },
      "POST /api/auth/refresh": {
        "description": "Refresh access token using refresh token",
        "auth": false,
        "headers": {
          "Content-Type": "application/json"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": {
          "refreshToken": { "type": "string", "required": true }
        },
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Token refreshed successfully",
            "data": {
              "accessToken": "string (JWT)",
              "refreshToken": "string (JWT)"
            }
          }
        }
      },
      "POST /api/auth/logout": {
        "description": "Logout (client-side token cleanup)",
        "auth": true,
        "headers": {
          "Authorization": "Bearer <accessToken>"
        },
        "pathParams": {},
        "queryParams": {},
        "requestBody": null,
        "successResponse": {
          "status": 200,
          "body": {
            "success": true,
            "message": "Logged out successfully",
            "data": null
