            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rajkotlive.in\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login (User - Rajesh)",
          "event": [
            {
              "listen": "test",
