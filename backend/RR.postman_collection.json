    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    },
    {
      "key": "commentId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
